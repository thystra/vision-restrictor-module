{
  "id": "vision-restrictor-module",
  "title": "Vision Restrictor",
  "description": "Applies a GM-configured hard maximum vision range for scenes, useful for fog, smoke, haze, blizzards, magical obscurity, or large open maps. The range is interpreted in the scene's configured distance units.",
  "version": "0.1.9",
  "url": "https://github.com/thystra/vision-restrictor-module",
  "manifest": "https://github.com/thystra/vision-restrictor-module/releases/latest/download/module.json",
  "download": "https://github.com/thystra/vision-restrictor-module/releases/latest/download/vision-restrictor-module.zip",
  "authors": [
    {
      "name": "Alan Johnson",
      "url": "https://github.com/thystra"
    },
    {
      "name": "thystra",
      "url": "https://github.com/thystra"
    }
  ],
  "compatibility": {
    "minimum": "14",
    "verified": "14.364"
  },
  "relationships": {
    "recommends": [
      {
        "id": "lib-wrapper",
        "type": "module",
        "reason": "Recommended for safer interoperability with other modules that wrap Foundry token and vision methods. Vision Restrictor falls back to direct wrapping if libWrapper is not installed."
      }
    ]
  },
  "esmodules": [
    "scripts/vision-restrictor.js"
  ],
  "styles": [
    "styles/vision-restrictor.css"
  ],
  "languages": [
    {
      "lang": "en",
      "name": "English",
      "path": "lang/en.json"
    }
  ],
  "license": "LICENSE",
  "readme": "README.md",
  "bugs": "https://github.com/thystra/vision-restrictor-module/issues",
  "changelog": "https://github.com/thystra/vision-restrictor-module/releases",
  "library": false
}
